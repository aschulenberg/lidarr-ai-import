# --- Lidarr connection ---
# Settings -> General -> Security -> API Key
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=

# --- AI provider ---
# One of: anthropic, openai, ollama
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=
# Only needed for ollama, or to point openai/anthropic at a custom-compatible endpoint
AI_BASE_URL=

# --- Safety ---
# Keep this true until you've reviewed a few runs of decision logs.
# In dry-run, decisions are computed and logged but never sent to Lidarr.
DRY_RUN=true
# 0.0-1.0. Decisions below this confidence are always left as needs_review, never auto-applied.
CONFIDENCE_THRESHOLD=0.85

# --- Timing ---
RESOLVER_POLL_SECONDS=300
RECONCILER_POLL_SECONDS=3600
# How long a needs_review/skip decision is remembered before we'll ask the AI again
# about the same file (minutes).
REPROCESS_COOLDOWN_MINUTES=720

# --- Storage / logging ---
DB_PATH=./data/lidarr_ai_import.db
LOG_LEVEL=INFO
